---
layout: null
permalink: /feed.xml
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.title | xml_escape }}</title>
  <subtitle>{{ site.description | xml_escape }}</subtitle>
  <link href="{{ '/feed.xml' | absolute_url }}" rel="self" type="application/atom+xml" />
  <link href="{{ '/' | absolute_url }}" rel="alternate" type="text/html" />
  <updated>{% assign newest = site.litreview | sort: 'date' | last %}{% if newest %}{{ newest.date | date_to_xmlschema }}{% else %}{{ site.time | date_to_xmlschema }}{% endif %}</updated>
  <id>{{ '/' | absolute_url }}</id>
  <author><name>{{ site.author | xml_escape }}</name></author>
  {% assign feed_posts = site.litreview | sort: 'date' | reverse %}
  {% for post in feed_posts limit: 30 %}
  <entry>
    <title>{{ post.title | xml_escape }}</title>
    <link href="{{ post.url | absolute_url }}" rel="alternate" type="text/html" />
    <published>{{ post.date | date_to_xmlschema }}</published>
    <updated>{{ post.date | date_to_xmlschema }}</updated>
    <id>{{ post.url | absolute_url }}</id>
    <summary type="html">{{ post.summary | default: post.excerpt | strip_html | xml_escape }}</summary>
  </entry>
  {% endfor %}
</feed>
